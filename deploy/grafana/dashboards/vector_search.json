{
  "__inputs": [],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "11.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"}
  ],
  "annotations": {"list": []},
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 100,
      "title": "HTTP Overview",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2},
          "unit": "reqps"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 1},
      "id": 1,
      "options": {"tooltip": {"mode": "multi"}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum(rate(vector_search_app_status_request_count_total{handler!~\"/docs|/metrics|/openapi.json|/redoc\"}[$__rate_interval])) by (handler)",
          "legendFormat": "{{handler}}",
          "refId": "A"
        }
      ],
      "title": "RPS by endpoint",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2},
          "unit": "reqps"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 1},
      "id": 2,
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum(rate(vector_search_app_status_request_count_total{handler!~\"/docs|/metrics|/openapi.json|/redoc\"}[$__rate_interval])) by (status)",
          "legendFormat": "HTTP {{status}}",
          "refId": "A"
        }
      ],
      "title": "RPS by status code",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 9},
      "id": 101,
      "title": "Latency",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2},
          "unit": "s"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 10},
      "id": 3,
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "histogram_quantile(0.50, sum(rate(vector_search_app_api_request_duration_seconds_bucket{handler!~\"/docs|/metrics|/openapi.json|/redoc\"}[$__rate_interval])) by (le, handler))",
          "legendFormat": "p50 {{handler}}",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "histogram_quantile(0.95, sum(rate(vector_search_app_api_request_duration_seconds_bucket{handler!~\"/docs|/metrics|/openapi.json|/redoc\"}[$__rate_interval])) by (le, handler))",
          "legendFormat": "p95 {{handler}}",
          "refId": "B"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "histogram_quantile(0.99, sum(rate(vector_search_app_api_request_duration_seconds_bucket{handler!~\"/docs|/metrics|/openapi.json|/redoc\"}[$__rate_interval])) by (le, handler))",
          "legendFormat": "p99 {{handler}}",
          "refId": "C"
        }
      ],
      "title": "Response time p50 / p95 / p99 by endpoint",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "red", "value": 5}
            ]
          },
          "unit": "s",
          "mappings": []
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 10},
      "id": 4,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "auto", "textMode": "auto", "colorMode": "background"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "histogram_quantile(0.95, sum(rate(vector_search_app_api_request_duration_seconds_bucket{handler!~\"/docs|/metrics|/openapi.json|/redoc\"}[$__rate_interval])) by (le, handler))",
          "legendFormat": "{{handler}}",
          "refId": "A"
        }
      ],
      "title": "p95 latency (current) by endpoint",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 18},
      "id": 102,
      "title": "Search Engine",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2},
          "unit": "s"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 19},
      "id": 5,
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "histogram_quantile(0.50, sum(rate(vector_search_app_search_duration_seconds_bucket[$__rate_interval])) by (le, query_type))",
          "legendFormat": "p50 {{query_type}}",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "histogram_quantile(0.95, sum(rate(vector_search_app_search_duration_seconds_bucket[$__rate_interval])) by (le, query_type))",
          "legendFormat": "p95 {{query_type}}",
          "refId": "B"
        }
      ],
      "title": "Search engine duration p50/p95 by query type",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2},
          "unit": "short"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 19},
      "id": 6,
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "histogram_quantile(0.50, sum(rate(vector_search_app_search_results_count_seconds_bucket[$__rate_interval])) by (le, query_type))",
          "legendFormat": "p50 {{query_type}}",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "histogram_quantile(0.95, sum(rate(vector_search_app_search_results_count_seconds_bucket[$__rate_interval])) by (le, query_type))",
          "legendFormat": "p95 {{query_type}}",
          "refId": "B"
        }
      ],
      "title": "Search results count p50/p95 by query type",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2},
          "unit": "short"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 27},
      "id": 7,
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "histogram_quantile(0.50, sum(rate(vector_search_app_search_text_query_length_seconds_bucket[$__rate_interval])) by (le))",
          "legendFormat": "p50 chars",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "histogram_quantile(0.95, sum(rate(vector_search_app_search_text_query_length_seconds_bucket[$__rate_interval])) by (le))",
          "legendFormat": "p95 chars",
          "refId": "B"
        }
      ],
      "title": "Text query length distribution",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2},
          "unit": "short"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 27},
      "id": 8,
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "histogram_quantile(0.50, sum(rate(vector_search_app_search_text_query_tokens_seconds_bucket[$__rate_interval])) by (le))",
          "legendFormat": "p50 tokens",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "histogram_quantile(0.95, sum(rate(vector_search_app_search_text_query_tokens_seconds_bucket[$__rate_interval])) by (le))",
          "legendFormat": "p95 tokens",
          "refId": "B"
        }
      ],
      "title": "Text query token count distribution",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 35},
      "id": 103,
      "title": "Error rates",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2},
          "unit": "percentunit"
        }
      },
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 36},
      "id": 9,
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum(rate(vector_search_app_status_request_count_total{status=~\"5..\",handler!~\"/docs|/metrics|/openapi.json|/redoc\"}[$__rate_interval])) by (handler) / sum(rate(vector_search_app_status_request_count_total{handler!~\"/docs|/metrics|/openapi.json|/redoc\"}[$__rate_interval])) by (handler)",
          "legendFormat": "5xx rate {{handler}}",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum(rate(vector_search_app_status_request_count_total{status=~\"4..\",handler!~\"/docs|/metrics|/openapi.json|/redoc\"}[$__rate_interval])) by (handler) / sum(rate(vector_search_app_status_request_count_total{handler!~\"/docs|/metrics|/openapi.json|/redoc\"}[$__rate_interval])) by (handler)",
          "legendFormat": "4xx rate {{handler}}",
          "refId": "B"
        }
      ],
      "title": "Error rate (4xx / 5xx) by endpoint",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["vector-search"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource",
        "label": "Datasource"
      },
      {
        "current": {},
        "datasource": {"type": "prometheus", "uid": "${datasource}"},
        "definition": "label_values(up{job=\"vector_search_service\"}, job)",
        "hide": 2,
        "name": "namespace",
        "query": {
          "query": "query_result(up{job=\"vector_search_service\"})",
          "refId": "namespace"
        },
        "refresh": 2,
        "regex": "",
        "type": "constant",
        "label": "Namespace",
        "query": "vector_search_app"
      }
    ]
  },
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "Vector Search Service",
  "uid": "vector-search-main",
  "version": 1
}
